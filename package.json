{
  "name": "gemini-bridge-mcp",
  "version": "2.0.0",
  "description": "Comprehensive MCP server for Google Gemini with NO API key: Gemini-CLI backend (ask, web search, deep research, code/file/URL analysis, structured output) + web-UI backend for image (Nano Banana) and video (Veo) generation.",
  "type": "module",
  "bin": {
    "gemini-bridge-mcp": "server.js"
  },
  "scripts": {
    "login": "node server.js login",
    "start": "node server.js",
    "http": "node server.js http",
    "tools": "node server.js tools"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "gemini",
    "google-gemini",
    "gemini-cli",
    "nano-banana",
    "veo",
    "web-search",
    "deep-research",
    "code-analysis",
    "image-generation",
    "video-generation",
    "playwright"
  ],
  "license": "MIT",
  "author": "NotFabii",
  "repository": {
    "type": "git",
    "url": "https://github.com/NotFabii/gemini-bridge-mcp.git"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "playwright-core": "^1.49.0"
  }
}
